<!DOCTYPE html>
<html>
<head>
    <title>Stock Ferretería</title>
</head>
<body>

<h1>Stock Ferretería</h1>

<form action="/agregar" method="post">
    Código: <input type="text" name="codigo">
    Nombre: <input type="text" name="nombre">
    Stock: <input type="number" name="stock">
    Precio: <input type="number" name="precio">
    <button type="submit">Agregar</button>
</form>

<h2>Productos</h2>

<table border="1">
<tr>
    <th>ID</th>
    <th>Código</th>
    <th>Nombre</th>
    <th>Stock</th>
    <th>Precio</th>
</tr>

{% for p in productos %}
<tr>
    <td>{{ p[0] }}</td>
    <td>{{ p[1] }}</td>
    <td>{{ p[2] }}</td>
    <td>{{ p[3] }}</td>
    <td>{{ p[4] }}</td>
</tr>
{% endfor %}

</table>

</body>
</html>
